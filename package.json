{
  "name": "la-crosse-to-wunderground",
  "version": "1.0.0",
  "description": "AWS service that fetches weather observations from La Crosse Alerts Mobile and submits them to a Weather Underground PWS.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "deploy": "./deploy.sh",
    "invoke": "aws lambda invoke --function-name la-crosse-to-wunderground-reader --region us-west-2 --payload '{\"count\": 3}' --cli-binary-format raw-in-base64-out $(tty)",
    "test": "jest"
  },
  "keywords": [],
  "author": "Mark Wainwright",
  "license": "UNLICENSED",
  "devDependencies": {
    "@tsconfig/node16": "^1.0.3",
    "@types/aws-lambda": "^8.10.101",
    "@types/jest": "^28.1.2",
    "@types/node": "^16.11.41",
    "jest": "^28.1.1",
    "ts-jest": "^28.0.5",
    "typescript": "^4.7.4"
  },
  "directories": {
    "doc": "doc",
    "test": "test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.113.0",
    "axios": "^0.27.2",
    "windrose": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markwainwright/la-crosse-to-wunderground-pws.git"
  },
  "bugs": {
    "url": "https://github.com/markwainwright/la-crosse-to-wunderground-pws/issues"
  },
  "homepage": "https://github.com/markwainwright/la-crosse-to-wunderground-pws#readme"
}
